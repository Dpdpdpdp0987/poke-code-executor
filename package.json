{
  "name": "poke-code-executor",
  "version": "1.0.0",
  "description": "Secure code execution environment for Python and JavaScript",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "docker:build:python": "docker build -f docker/Dockerfile.python -t poke-executor-python .",
    "docker:build:node": "docker build -f docker/Dockerfile.node -t poke-executor-node .",
    "docker:build:all": "npm run docker:build:python && npm run docker:build:node",
    "db:migrate": "node scripts/migrate.js"
  },
  "dependencies": {
    "next": "^14.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@supabase/supabase-js": "^2.39.0",
    "dockerode": "^4.0.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "limiter": "^2.1.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}